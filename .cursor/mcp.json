{
    "mcpServers": {
        "laravel-boost": {
            "command": "php",
            "args": [
                "artisan",
                "boost:mcp"
            ]
        },
        "tailwindcss-server": {
            "command": "npx",
            "args": ["-y", "tailwindcss-mcp-server"]
        },
        "mediaProcessor": {
            "command": "npx",
            "args": ["-y", "create-mcp-server@latest"]
        },
        "mcp-copy-web-ui": {
            "command": "npx",
            "args": ["-y", "mcp-copy-web-ui"]
        }
    }
}