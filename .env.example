APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=he
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Logging: stack → single/daily; level = debug|info|warning|error
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Optional: Twilio SDK debug (request/response to error_log + Laravel Log when SMS sent). Unset or empty = off.
# TWILIO_LOG_LEVEL=debug

# --- Database: use a NEW database for RSVP + Seating MVP (do not use existing app DB) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=kalfa_rsvp
DB_USERNAME=
DB_PASSWORD=

# MySQL alternative (if not using PostgreSQL):
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=kalfa_rsvp
# DB_USERNAME=
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Billing: stub (local) or sumit. When sumit, set redirect URLs and officeguy credentials.
BILLING_GATEWAY=stub
# BILLING_SUMIT_SUCCESS_URL=https://your-frontend.example/checkout/success
# BILLING_SUMIT_CANCEL_URL=https://your-frontend.example/checkout/cancel
# Optional: when set, SUMIT webhooks must include X-Webhook-Signature (HMAC-SHA256).
# BILLING_WEBHOOK_SECRET=

# SUMIT (officeguy/laravel-sumit-gateway). Required when BILLING_GATEWAY=sumit.
# Map from SUMIT dashboard: CompanyID → OFFICEGUY_COMPANY_ID, APIKey (private) → OFFICEGUY_PRIVATE_KEY, APIPublicKey → OFFICEGUY_PUBLIC_KEY.
# OFFICEGUY_ENVIRONMENT=www
# OFFICEGUY_COMPANY_ID=
# OFFICEGUY_PRIVATE_KEY=
# OFFICEGUY_PUBLIC_KEY=
