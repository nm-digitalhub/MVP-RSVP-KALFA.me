APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=he
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

# Logging: stack → single/daily; level = debug|info|warning|error
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Optional: Twilio SDK debug (request/response to error_log + Laravel Log when SMS sent). Unset or empty = off.
# TWILIO_LOG_LEVEL=debug

# --- Database: use a NEW database for RSVP + Seating MVP (do not use existing app DB) ---
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=kalfa_rsvp
DB_USERNAME=
DB_PASSWORD=

# Read Replica (optional — defaults to primary above if not set)
# For production with read replicas, configure these separately:
# DB_READ_HOST=127.0.0.1
# DB_READ_PORT=5432
# DB_READ_DATABASE=kalfa_rsvp
# DB_READ_USERNAME=
# DB_READ_PASSWORD=
# DB_READ_TIMEOUT=5

# MySQL alternative (if not using PostgreSQL):
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=kalfa_rsvp
# DB_USERNAME=
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=redis
# TaggedCache uses a tag-capable store (Redis by default). For PHPUnit use array:
# CACHE_TAGGED_STORE=array
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

# Redis (tag-based cache with predis)
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_DB=0
REDIS_CACHE_DB=1

# Pulse APM (Application Performance Monitoring)
PULSE_ENABLED=true
PULSE_PATH=pulse
PULSE_STORAGE_DRIVER=database
PULSE_INGEST_DRIVER=storage
PULSE_CACHE_DRIVER=redis
PULSE_REDIS_CONNECTION=default

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
TALLSTACKUI_PREFIX=ts-

# Billing: stub (local) or sumit. When sumit, set redirect URLs and officeguy credentials.
BILLING_GATEWAY=stub
# BILLING_SUMIT_SUCCESS_URL=https://your-frontend.example/checkout/success
# BILLING_SUMIT_CANCEL_URL=https://your-frontend.example/checkout/cancel
# Optional: when set, SUMIT webhooks must include X-Webhook-Signature (HMAC-SHA256).
# BILLING_WEBHOOK_SECRET=

# SUMIT (officeguy/laravel-sumit-gateway). Required when BILLING_GATEWAY=sumit.
# Map from SUMIT dashboard: CompanyID → OFFICEGUY_COMPANY_ID, APIKey (private) → OFFICEGUY_PRIVATE_KEY, APIPublicKey → OFFICEGUY_PUBLIC_KEY.
# OFFICEGUY_ENVIRONMENT=www
# OFFICEGUY_COMPANY_ID=
# OFFICEGUY_PRIVATE_KEY=
# OFFICEGUY_PUBLIC_KEY=

# Twilio (voice, Verify, WhatsApp). Account SID and Auth Token from Console.
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_NUMBER=   (voice; E.164, e.g. +972...)
# For WhatsApp RSVP link: Sandbox +14155238886 or your WhatsApp Business number. If unset, TWILIO_NUMBER is used.
# With Sandbox: each recipient must first send "join <word>" to +14155238886 (word = in Twilio Console → Messaging → Try WhatsApp).
# TWILIO_WHATSAPP_FROM=
# Twilio Verify (OTP via WhatsApp/SMS). Create a Verify Service in Console, then set SID (starts with VA).
# TWILIO_VERIFY_SID=

# -----------------------------------------------------------------------------
# NativePHP Mobile (iOS / Android). See docs/nativephp/deployment-guide.md
# Tracked template only — copy values into .env / .env.production; mirror keys in .env.testing for tests.
# -----------------------------------------------------------------------------
# Mobile shell API base (config/mobile.php, Vite) — כמו ב-.env לפרודקשן.
# VITE_MOBILE_API_BASE_URL=https://kalfa.me

# זהות אפליקציה (ערכי ברירת מחדל בפרויקט; לפיתוח אפשר NATIVEPHP_APP_VERSION=DEBUG)
# NATIVEPHP_APP_ID=me.kalfa.eventrsvp
# NATIVEPHP_APP_VERSION=1.0.0
# NATIVEPHP_APP_VERSION_CODE=1
# NATIVEPHP_START_URL=/mobile
# NATIVEPHP_DEEPLINK_SCHEME=kalfa
# NATIVEPHP_DEEPLINK_HOST=kalfa.me
#
# Universal Links / App Links — Laravel serves:
#   https://<NATIVEPHP_DEEPLINK_HOST>/.well-known/apple-app-site-association
#   https://<NATIVEPHP_DEEPLINK_HOST>/.well-known/assetlinks.json
# AASA uses NATIVEPHP_APP_ID + NATIVEPHP_DEVELOPMENT_TEAM (TeamID.bundle_id).
# Optional: include webcredentials for passkeys (same host). Set false to omit.
# NATIVEPHP_AASA_WEBCREDENTIALS=true
#
# Android App Links: comma-separated SHA-256 cert fingerprints (upload / Play App Signing).
# NATIVEPHP_ANDROID_PACKAGE_NAME=me.kalfa.eventrsvp
# NATIVEPHP_ANDROID_ASSETLINKS_SHA256=

# Apple Team ID — הזן מ-https://developer.apple.com/account (Membership). חייב להתאים ל-IOS_TEAM_ID.
# NATIVEPHP_DEVELOPMENT_TEAM=3P6C82QTRL
# IOS_TEAM_ID=${NATIVEPHP_DEVELOPMENT_TEAM}

# -----------------------------------------------------------------------------
# iOS packaging & App Store Connect (paths relative to project root)
# -----------------------------------------------------------------------------
# Keep real files under credentials/ (directory is gitignored). Do not commit
# .p12, .p8, .mobileprovision, or private keys.
#
# חתימת iOS — אותם נתיבים כמו בפרויקט (קבצים תחת credentials/, לא ב-git)
# IOS_DISTRIBUTION_CERTIFICATE_PATH=credentials/distribution.p12
# IOS_DISTRIBUTION_CERTIFICATE_PASSWORD=
# IOS_DISTRIBUTION_PROVISIONING_PROFILE_PATH=credentials/profile.mobileprovision
#
# App Store Connect API — מפתח .p8 בפועל ב-repo מקומי (שם הקובץ כפי שהורד מ-App Store Connect)
# APP_STORE_API_KEY_PATH=credentials/AuthKey_6X5674BGPC.p8
# APP_STORE_API_KEY_ID=6X5674BGPC
# APP_STORE_API_ISSUER_ID=f6b7bf87-b2fb-4b05-812b-30efbdb54a3c
# APP_STORE_APP_NAME=
#
# config/nativephp.php also supports APP_STORE_API_KEY (key contents). Prefer
# APP_STORE_API_KEY_PATH locally so the .p8 file never sits inline in .env.
#
# Reference only (cert creation / renewal on your Mac; not required at runtime
# for native:package if .p12 + profile are already valid):
# - credentials/distribution.cer
# - credentials/ios-private-key.key
# - credentials/ios-certificate-request.csr

# -----------------------------------------------------------------------------
# Panel screenshots (spatie/laravel-screenshot + Browsershot / Puppeteer)
# -----------------------------------------------------------------------------
# If php artisan runs as root, Chrome needs --no-sandbox. Config defaults to
# that on POSIX when euid is 0; set explicitly when you need to override:
# LARAVEL_SCREENSHOT_NO_SANDBOX=true
# LARAVEL_SCREENSHOT_NO_SANDBOX=false
# LARAVEL_SCREENSHOT_CHROME_PATH=
#
# Authenticated captures: php artisan panel:capture-screenshots --auth --url=/dashboard
# Full set (dashboard + billing + system admin routes, etc.):
#   php artisan panel:capture-screenshots --auth --all
# (session cookies via web login; see Spatie customizing-browsershot / useCookies).
# PANEL_SCREENSHOT_LOGIN_EMAIL=
# PANEL_SCREENSHOT_LOGIN_PASSWORD=
# Or reuse CAPTURE_EMAIL / CAPTURE_PASSWORD from Playwright capture scripts.
#
# Optional: override the entire --all list (comma-separated paths)
# PANEL_SCREENSHOT_AUTH_ALL_PATHS=
# PANEL_SCREENSHOT_EVENT_ID=1
# PANEL_SCREENSHOT_SYSTEM_ORG_ID=1
# PANEL_SCREENSHOT_SYSTEM_ACCOUNT_ID=1
# PANEL_SCREENSHOT_SYSTEM_USER_ID=1
# PANEL_SCREENSHOT_PRODUCT_ID=1
#
# Optional: staging behind HTTP Basic (Browsershot::authenticate)
# PANEL_SCREENSHOT_HTTP_BASIC_USER=
# PANEL_SCREENSHOT_HTTP_BASIC_PASSWORD=
