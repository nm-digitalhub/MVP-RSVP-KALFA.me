# ============================================
# NativePHP Mobile — mirror .env.example / docs/nativephp/deployment-guide.md
# ============================================
# VITE_MOBILE_API_BASE_URL is set at the top of this file (config/mobile.php + Vite).

# App identity
NATIVEPHP_START_URL=/mobile
NATIVEPHP_APP_ID=me.kalfa.eventrsvp
NATIVEPHP_APP_VERSION=1.0.0
NATIVEPHP_APP_VERSION_CODE=1
NATIVEPHP_DEEPLINK_SCHEME=kalfa
NATIVEPHP_DEEPLINK_HOST=kalfa.me

# Universal Links / App Links — Laravel serves /.well-known/* (see routes/web.php)
NATIVEPHP_AASA_WEBCREDENTIALS=true
NATIVEPHP_ANDROID_PACKAGE_NAME=me.kalfa.eventrsvp
# Google Play → App integrity / App signing: SHA-256 certificate fingerprint(s), comma-separated. Required for verified App Links.
NATIVEPHP_ANDROID_ASSETLINKS_SHA256=

# Apple Developer → Membership → Team ID (10 characters). Used by config/nativephp.php (Xcode project).
NATIVEPHP_DEVELOPMENT_TEAM=3P6C82QTRL
# NativePHP native:package ios reads IOS_TEAM_ID per https://nativephp.com/docs/mobile/3/getting-started/deployment#ios-packaging — keep identical to NATIVEPHP_DEVELOPMENT_TEAM.
IOS_TEAM_ID=${NATIVEPHP_DEVELOPMENT_TEAM}

# iOS signing — paths under credentials/ (gitignored). Password: required in .env for `php artisan native:package ios` when using env-based signing (same docs). Re-enter your .p12 export password here locally; do not commit .env.
IOS_DISTRIBUTION_CERTIFICATE_PATH=credentials/distribution.p12
IOS_DISTRIBUTION_CERTIFICATE_PASSWORD="13579Net!!"
IOS_DISTRIBUTION_PROVISIONING_PROFILE_PATH=credentials/profile.mobileprovision

# App Store Connect API (.p8: Users and Access → Keys)
APP_STORE_API_KEY_PATH=credentials/AuthKey_6X5674BGPC.p8
APP_STORE_API_KEY_ID=6X5674BGPC
APP_STORE_API_ISSUER_ID=f6b7bf87-b2fb-4b05-812b-30efbdb54a3c
APP_STORE_APP_NAME=

# Cert renewal artifacts only (not needed for packaging if .p12 + profile are valid):
# credentials/distribution.cer, credentials/ios-private-key.key, credentials/ios-certificate-request.csr
TALLSTACKUI_PREFIX=ts-
